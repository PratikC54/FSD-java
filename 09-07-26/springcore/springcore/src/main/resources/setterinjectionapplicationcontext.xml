<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="specification" class="com.setterinjectionusingxml.Specification" >
        <property name="maker" value="Tata" />
        <property name="model" value="harrier" />

    </bean>
    <bean id="car" class="com.setterinjectionusingxml.Car">
        <property name="specification" ref="specification" />
    </bean>

</beans>