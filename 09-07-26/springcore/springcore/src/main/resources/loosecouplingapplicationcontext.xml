<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="upipayment" class="com.loosecouplingbean.UpiPayment"></bean>
    <bean id="cardpayment" class="com.loosecouplingbean.CreditCardPayment"></bean>

    <bean id="shopingcartbyupi" class="com.loosecouplingbean.ShoppingCart">
        <constructor-arg ref="upipayment" />
    </bean>

    <bean id="shopingcartbycard" class="com.loosecouplingbean.ShoppingCart">
        <constructor-arg ref="cardpayment" />
    </bean>

</beans>